# Enforces Conventional Commits: https://www.conventionalcommits.org
# Format:  type(scope): description
# Example: feat(auth): add biometric login

COMMIT_MSG=$(cat "$1")
PATTERN="^(feat|fix|chore|docs|style|refactor|perf|test|build|ci|revert)(\(.+\))?: .{1,100}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "❌  Invalid commit message format."
  echo ""
  echo "    Expected:  type(scope): short description"
  echo "    Examples:  feat(auth): add biometric login"
  echo "               fix: crash on deep link navigation"
  echo "               chore(deps): bump nativewind to v4"
  echo ""
  exit 1
fi
