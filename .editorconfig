# EditorConfig — ensures consistent formatting across editors/IDEs
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
# Don't trim trailing whitespace in Markdown (two spaces = line break)
trim_trailing_whitespace = false
max_line_length = off

[*.json]
indent_size = 2

[Makefile]
indent_style = tab
